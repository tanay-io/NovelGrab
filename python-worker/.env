# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Python Scraper Backend
SCRAPER_URL=http://localhost:8000

# Object Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=../node-api/storage

# S3-compatible storage
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=novelgrab
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
