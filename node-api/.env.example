# ─────────────────────────────────────────────
# NovelGrab Node API – Environment Configuration
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://admin:neeru2005@cluster0.mou2u4p.mongodb.net/

# Redis (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Python Scraper Backend (existing FastAPI)
PYTHON_SCRAPER_URL=http://localhost:8000

# Object Storage (S3-compatible: AWS S3 / Cloudflare R2 / MinIO)
STORAGE_PROVIDER=local
# For S3/R2:
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=novelgrab
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# For local storage (development)
LOCAL_STORAGE_PATH=./storage

# CDN Base URL (optional, for production)
CDN_BASE_URL=

# Engagement / Prefetch
PREFETCH_AHEAD=5
ARTIFACT_TRIGGER_CHAPTERS=5
